{
  "name": "brazil_vs_morocco",
  "displayName": "Brazil vs Morocco",
  "version": "1.0.0",
  "initialState": {
    "chatMessages": [
      {
        "messageType": "system",
        "text": "Watch the video on the right to learn about the Brazil vs Morocco match. When you're done, we'll test your knowledge!"
      }
    ],
    "leftWidth": "25%"
  },
  "handlers": {
    "initializeState": {
      "steps": [
        {
          "route": "database-query",
          "query": {
            "name": "get-document",
            "responseType": "initialize-state-document"
          }
        }
      ]
    },
    "initialize-state-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-client",
            "initialState": "$message.document.state",
            "layoutConfig": []
          }
        }
      ]
    },
    "defaultView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-client",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "twoColumnLayout",
                "props": { "leftWidth": "@state.leftWidth" },
                "children": [
                  {
                    "componentType": "chatBody",
                    "props": {
                      "messages": "@state.chatMessages"
                    }
                  },
                  {
                    "componentType": "youtubePlayer",
                    "props": {
                      "videoId": "0rih2fCaXF4"
                    },
                    "emits": {
                      "videoEnd": "video-ended"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "video-ended": {
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "append",
                "path": "$state.chatMessages",
                "value": {
                  "messageType": "system",
                  "text": "Good job, now you are ready for a quiz"
                }
              },
              {
                "actionType": "append",
                "path": "$state.chatMessages",
                "value": {
                  "id": "$uuid",
                  "messageType": "multiple-choice-quiz",
                  "answer": null,
                  "question": "What happened in the game?",
                  "correctKey": "C",
                  "options": [
                    { "key": "A", "label": "Morocco won!", "feedback": "Not quite — Morocco played well but didn't take the win." },
                    { "key": "B", "label": "Brazil won!", "feedback": "That's not right — Brazil didn't win this one." },
                    { "key": "C", "label": "It was a tie", "feedback": "Correct! The match ended in a draw." },
                    { "key": "D", "label": "The game was cancelled", "feedback": "Nope — the game was played to completion." }
                  ],
                  "emits": { "answer": "quiz-answer" }
                }
              },
              {
                "actionType": "update",
                "path": "$state.leftWidth",
                "value": "60%"
              }
            ]
          }
        }
      ]
    },
    "quiz-answer": {
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "update-in",
                "path": "$state.chatMessages",
                "findKey": "id",
                "findValue": "$message.formId",
                "subPath": "answer",
                "value": "$message.key"
              }
            ]
          }
        }
      ]
    }
  }
}
