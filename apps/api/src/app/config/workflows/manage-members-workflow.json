{
  "name": "manage-members-workflow",
  "version": "1.0.0",
  "initialState": {},
  "handlers": {
    "initializeState": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": {}
          }
        }
      ]
    },
    "defaultView": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "textDisplay",
                    "props": { "text": "Manage Members" }
                  },
                  {
                    "componentType": "memberList",
                    "props": {
                      "items": "@temp.members",
                      "isAdmin": "@temp.isAdmin"
                    },
                    "emits": { "remove": "remove-member", "roleChange": "update-member-role" }
                  },
                  {
                    "componentType": "showIf",
                    "props": { "source": "@temp.isAdmin" },
                    "children": [
                      {
                        "componentType": "multiFieldInput",
                        "props": {
                          "fields": [
                            { "name": "email", "label": "Email", "placeholder": "user@example.com" }
                          ],
                          "submitLabel": "Add Member"
                        },
                        "emits": { "submit": "add-member" }
                      }
                    ]
                  },
                  {
                    "componentType": "textDisplay",
                    "props": { "text": "@temp.result" }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "database-query",
          "query": { "name": "get-group-members", "responseType": "members-loaded" }
        }
      ]
    },
    "members-loaded": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.members", "value": "$message.members" },
              { "actionType": "update", "path": "$temp.isAdmin", "value": "$message.isAdmin" }
            ]
          }
        }
      ]
    },
    "add-member": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "add-group-member", "responseType": "member-mutation-result" }
        }
      ]
    },
    "update-member-role": {
      "condition": "$message._id",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "update-group-member-role", "responseType": "member-mutation-result" }
        }
      ]
    },
    "remove-member": {
      "condition": "$message._id",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "remove-group-member", "responseType": "member-mutation-result" }
        }
      ]
    },
    "member-mutation-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.result", "value": "$message.result" }
            ]
          }
        },
        {
          "route": "database-query",
          "query": { "name": "get-group-members", "responseType": "members-loaded" }
        }
      ]
    }
  }
}
