{
  "name": "user-dashboard-workflow",
  "version": "1.0.0",
  "handlers": {
    "initialize": {
      "transformer": "simple",
      "steps": [
        {
          "route": "database-query",
          "query": {
            "name": "get-user-documents",
            "responseType": "document-list-result"
          }
        }
      ]
    },
    "get-document-list": {
      "steps": [
        {
          "route": "database-query",
          "query": {
            "name": "get-user-documents",
            "responseType": "document-list-result"
          }
        }
      ]
    },
    "document-list-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "append",
                "path": "documents",
                "value": "$message.documents"
              }
            ]
          }
        }
      ]
    },
    "select-document": {
      "steps": [
        {
          "route": "database-query",
          "query": {
            "name": "get-document",
            "responseType": "display-document-result"
          }
        }
      ]
    },
    "display-document-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "append",
                "path": "selectedDocument",
                "value": "$message.document"
              }
            ]
          }
        }
      ]
    },
    "create-document": {
      "transformer": "simple",
      "condition": "$message.name",
      "steps": [
        {
          "route": "database-query",
          "query": {
            "name": "create-document",
            "responseType": "document-created-result"
          }
        }
      ]
    },
    "document-created-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "append",
                "path": "documents",
                "value": "$message.documents"
              },
              {
                "actionType": "append",
                "path": "selectedDocument",
                "value": "$message.document"
              }
            ]
          }
        }
      ]
    }
  }
}