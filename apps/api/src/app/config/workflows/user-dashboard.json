{
  "name": "user-dashboard-workflow",
  "version": "1.0.0",
  "initialState": {
    "openDocs": [],
    "openAccordions": {
      "documents": "documents",
      "groups": "groups"
    },
    "config": {
      "staticTabTitles": ["Dashboard"],
      "userManagementViewHandler": "userManagementView",
      "sectionIdField": "id",
      "sectionTriggerFields": ["label"],
      "documentSection": [{ "id": "documents", "label": "Documents" }],
      "groupSection":   [{ "id": "groups",    "label": "Groups"    }],
      "availableTypes": ["configged-chat", "log-review"]
    }
  },
  "handlers": {
    "initialize": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-document", "responseType": "initialize-document" }
        }
      ]
    },
    "initialize-document": {
      "transformer": "simple",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-client",
            "viewHandler": "initialize",
            "initialState": "$message.document.state",
            "layoutConfig": [
              {
                "componentType": "smartTabs",
                "props": { "tabTitles": "state.config.staticTabTitles" },
                "childTemplate": {
                  "source": "state.openDocs",
                  "idField": "_id",
                  "titleField": "name",
                  "template": {
                    "componentType": "layoutDocumentView",
                    "props": { "channelId": "item.currentChannelId" }
                  }
                },
                "children": [
                  {
                    "componentType": "layoutDocumentView",
                    "props": {
                      "channelId": "temp._channelId",
                      "viewHandler": "state.config.userManagementViewHandler"
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "temp._channelId", "value": "$message.document.currentChannelId" }
            ]
          }
        }
      ]
    },
    "userManagementView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-client",
            "viewHandler": "userManagementView",
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "smartAccordion",
                    "props": {
                      "items":         "state.config.documentSection",
                      "idField":       "state.config.sectionIdField",
                      "triggerFields": "state.config.sectionTriggerFields",
                      "defaultValue":  "state.openAccordions.documents"
                    },
                    "emits": { "select": "save-documents-accordion" },
                    "children": [
                      {
                        "componentType": "documentList",
                        "props": { "items": "temp.documentList" },
                        "emits": { "select": "select-document" }
                      },
                      {
                        "componentType": "newDocument",
                        "props": { "availableTypes": "state.config.availableTypes" },
                        "emits": { "create": "create-document" }
                      }
                    ]
                  },
                  {
                    "componentType": "smartAccordion",
                    "props": {
                      "items":         "state.config.groupSection",
                      "idField":       "state.config.sectionIdField",
                      "triggerFields": "state.config.sectionTriggerFields",
                      "defaultValue":  "state.openAccordions.groups"
                    },
                    "emits": { "select": "save-groups-accordion" }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "database-query",
          "query": { "name": "get-user-documents", "responseType": "document-list-result" }
        }
      ]
    },
    "get-document-list": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-user-documents", "responseType": "document-list-result" }
        }
      ]
    },
    "document-list-result": {
      "transformer": "simple",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "temp.documentList", "value": "$message.documents" }
            ]
          }
        }
      ]
    },
    "select-document": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-document-summary", "responseType": "display-document-result" }
        }
      ]
    },
    "display-document-result": {
      "transformer": "simple",
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "upsert",
                "path": "state.openDocs",
                "value": "$message.document",
                "keys": ["_id"]
              }
            ]
          }
        }
      ]
    },
    "create-document": {
      "transformer": "simple",
      "condition": "$message.name",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "create-document", "responseType": "document-created-result" }
        }
      ]
    },
    "document-created-result": {
      "transformer": "simple",
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "upsert",
                "path": "state.openDocs",
                "value": "$message.document",
                "keys": ["_id"]
              }
            ]
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "upsert",
                "path": "temp.documentList",
                "value": "$message.document",
                "keys": ["_id"]
              }
            ]
          }
        }
      ]
    },
    "save-documents-accordion": {
      "transformer": "simple",
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "state.openAccordions.documents", "value": "$message.id" }
            ]
          }
        }
      ]
    },
    "save-groups-accordion": {
      "transformer": "simple",
      "steps": [
        {
          "route": ["client", "database"],
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "state.openAccordions.groups", "value": "$message.id" }
            ]
          }
        }
      ]
    }
  }
}
