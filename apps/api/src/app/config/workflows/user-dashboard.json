{
  "name": "user-dash",
  "version": "1.0.0",
  "initialState": {},
  "handlers": {
    "initializeState": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-user-groups", "responseType": "user-groups-result" }
        }
      ]
    },
    "user-groups-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": {}
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.groups", "value": "$message.groups" }
            ]
          }
        }
      ]
    },
    "defaultView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "textDisplay",
                    "props": { "text": "Welcome to your dashboard." }
                  },
                  {
                    "componentType": "showIfItems",
                    "props": { "source": "@temp.groups" },
                    "children": [
                      {
                        "componentType": "forEach",
                        "props": { "source": "@temp.groups" },
                        "children": [
                          {
                            "componentType": "groupNavItem",
                            "props": { "name": "@item.name", "id": "@item._id" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "componentType": "showIfEmpty",
                    "props": { "source": "@temp.groups" },
                    "children": [
                      {
                        "componentType": "textDisplay",
                        "props": { "text": "You are not a member of any groups. Contact a group administrator to be added." }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
