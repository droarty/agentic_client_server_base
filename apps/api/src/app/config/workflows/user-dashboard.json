{
  "name": "user-dash",
  "version": "1.0.0",
  "initialState": {},
  "handlers": {
    "initializeState": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-user-groups", "responseType": "user-groups-result" }
        }
      ]
    },
    "user-groups-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": {}
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.groups", "value": "$message.groups" },
              {
                "actionType": "update",
                "path": "$temp.sidebarItems",
                "value": "~{ [{ 'name': 'Groups', 'collapsible': true, 'children': [message.groups.{ '_id': _id, 'name': name, 'emits_msg': 'open-group' }] }] }"
              }
            ]
          }
        }
      ]
    },
    "defaultView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "twoColumnLayout",
                "props": { "leftWidth": "220px" },
                "children": [
                  {
                    "componentType": "sidebarMenu",
                    "props": { "items": "@temp.sidebarItems" }
                  },
                  {
                    "componentType": "textDisplay",
                    "props": { "text": "Select a group from the menu." }
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "open-group": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "redirect",
            "url": "~{ '/group/' & message._id }"
          }
        }
      ]
    }
  }
}
