{
  "name": "user-dash",
  "version": "1.0.0",
  "initialState": { "groups": [], "noGroupsMessage": "" },
  "handlers": {
    "initializeState": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-user-groups", "responseType": "user-groups-result" }
        }
      ]
    },
    "user-groups-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": {
              "groups": "$message.groups",
              "noGroupsMessage": "~{ $count($message.groups) = 0 ? 'You are not a member of any groups. Contact a group administrator to be added.' : '' }"
            }
          }
        }
      ]
    },
    "defaultView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "textDisplay",
                    "props": { "text": "Welcome to your dashboard." }
                  },
                  {
                    "componentType": "textDisplay",
                    "props": {
                      "text": "@state.noGroupsMessage",
                      "placeholder": ""
                    }
                  },
                  {
                    "componentType": "forEach",
                    "props": { "source": "@state.groups" },
                    "children": [
                      {
                        "componentType": "textDisplay",
                        "props": { "text": "@item.name" }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  }
}
