{
  "name": "group-dashboard",
  "version": "1.0.0",
  "initialState": {
    "config": {
      "recentDocumentLimit": 10
    }
  },
  "handlers": {
    "initializeState": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-channel-document", "responseType": "initialize-state-document" }
        }
      ]
    },
    "initialize-state-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": "$message.document.state"
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp._channelId", "value": "$message.channel" },
              { "actionType": "update", "path": "$temp.permissionLevel", "value": "$permissionLevel" }
            ]
          }
        }
      ]
    },
    "defaultView": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "twoColumnLayout",
                "props": { "leftWidth": "280px" },
                "children": [
                  {
                    "componentType": "sidebarMenu",
                    "props": { "items": "@temp.sidebarItems" }
                  },
                  {
                    "componentType": "textDisplay",
                    "props": {
                      "text": "@temp.rightPanelText",
                      "placeholder": "Select an item from the sidebar."
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "parallel-queries",
          "queries": [
            { "name": "get-recent-user-documents", "key": "documents" },
            { "name": "get-user-groups", "key": "groups" }
          ],
          "responseType": "dashboard-data-result"
        }
      ]
    },
    "dashboard-data-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "update",
                "path": "$temp.sidebarItems",
                "value": "~{ [ { 'name': 'My Documents', 'collapsible': true, 'children': $append(message.documents.{ '_id': _id, 'name': name, 'emits_msg': 'select-group-document' }, [{ 'name': 'Browse All Documents', '_id': 'browse-all', 'emits_msg': 'open-artifact-browser' }, { 'name': 'Create New Document', '_id': 'create-document', 'emits_msg': 'create-new-document' }]) }, { 'name': 'My Groups', 'collapsible': true, 'children': $append(message.groups.{ '_id': _id, 'name': name, 'emits_msg': 'open-group' }, [{ 'name': 'Create New Group', '_id': 'create-group', 'emits_msg': 'create-new-group' }]) } ] }"
              }
            ]
          }
        }
      ]
    },
    "open-artifact-browser": {
      "condition": "$message._id",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [{ "actionType": "update", "path": "$temp.rightPanelText", "value": "Artifact Browser — coming soon." }]
          }
        }
      ]
    },
    "select-group-document": {
      "condition": "$message._id",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [{ "actionType": "update", "path": "$temp.rightPanelText", "value": "Document View — coming soon." }]
          }
        }
      ]
    },
    "open-group": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "redirect",
            "url": "~{ '/group/' & message._id }"
          }
        }
      ]
    },
    "create-new-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [{ "actionType": "update", "path": "$temp.rightPanelText", "value": "Create New Document — coming soon." }]
          }
        }
      ]
    },
    "create-new-group": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [{ "actionType": "update", "path": "$temp.rightPanelText", "value": "Create New Group — coming soon." }]
          }
        }
      ]
    }
  }
}
