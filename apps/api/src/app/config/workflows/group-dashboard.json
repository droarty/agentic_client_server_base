{
  "name": "group-dashboard",
  "version": "1.0.0",
  "initialState": {
    "config": {
      "recentDocumentLimit": 10
    }
  },
  "handlers": {
    "initializeState": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-channel-document", "responseType": "initialize-state-document" }
        }
      ]
    },
    "initialize-state-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": "$message.document.state"
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp._channelId", "value": "$message.channel" },
              { "actionType": "update", "path": "$temp.permissionLevel", "value": "$permissionLevel" },
              { "actionType": "update", "path": "$temp.groupId", "value": "$groupId" }
            ]
          }
        }
      ]
    },
    "defaultView": {
      "requiredAccess": "read",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "twoColumnLayout",
                "props": { "leftWidth": "280px" },
                "children": [
                  {
                    "componentType": "sidebarMenu",
                    "props": { "items": "@temp.sidebarItems" }
                  },
                  {
                    "componentType": "layoutDocumentView",
                    "props": {
                      "channelId": "@temp.nestedChannelId",
                      "workflowType": "@temp.selectedWorkflow",
                      "groupId": "@temp.groupId",
                      "parentChannelId": "@temp._channelId",
                      "responseHandler": "group-created"
                    }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "parallel-queries",
          "queries": [
            { "name": "get-recent-user-documents", "key": "documents" },
            { "name": "get-subgroups", "key": "groups" }
          ],
          "responseType": "dashboard-data-result"
        }
      ]
    },
    "dashboard-data-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              {
                "actionType": "update",
                "path": "$temp.sidebarItems",
                "value": [
                  {
                    "name": "Group Documents",
                    "collapsed": false,
                    "children": {
                      "$map": "$message.documents",
                      "$using": { "_id": "$item._id", "name": "$item.name", "emits_msg": "select-group-document" },
                      "$append": [
                        { "name": "Browse All Documents", "_id": "browse-all", "emits_msg": "open-artifact-browser" },
                        { "name": "Create New Document", "_id": "create-document", "emits_msg": "create-new-document" }
                      ]
                    }
                  },
                  {
                    "name": "Sub Groups",
                    "collapsed": false,
                    "children": {
                      "$map": "$message.groups",
                      "$using": { "_id": "$item._id", "name": "$item.name", "emits_msg": "open-group" },
                      "$append": [
                        { "name": "Create New Group", "_id": "create-group", "emits_msg": "create-new-group" }
                      ]
                    }
                  },
                  { "name": "Manage Members", "_id": "manage-members", "emits_msg": "open-manage-members" }
                ]
              }
            ]
          }
        }
      ]
    },
    "open-artifact-browser": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.nestedChannelId", "value": null },
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": null }
            ]
          }
        }
      ]
    },
    "select-group-document": {
      "condition": "$message._id",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-document-summary", "responseType": "document-channel-ready" }
        }
      ]
    },
    "document-channel-ready": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.nestedChannelId", "value": "$message.document.currentChannelId" },
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": null }
            ]
          }
        }
      ]
    },
    "open-group": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "redirect",
            "url": "~{ '/group/' & message._id }"
          }
        }
      ]
    },
    "create-new-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.nestedChannelId", "value": null },
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": null }
            ]
          }
        }
      ]
    },
    "create-new-group": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": "create-new-group-workflow" },
              { "actionType": "update", "path": "$temp.nestedChannelId", "value": null }
            ]
          }
        }
      ]
    },
    "open-manage-members": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": "manage-members-workflow" },
              { "actionType": "update", "path": "$temp.nestedChannelId", "value": null }
            ]
          }
        }
      ]
    },
    "group-created": {
      "condition": "$message.group",
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.selectedWorkflow", "value": null }
            ]
          }
        },
        {
          "route": "parallel-queries",
          "queries": [
            { "name": "get-recent-user-documents", "key": "documents" },
            { "name": "get-subgroups", "key": "groups" }
          ],
          "responseType": "dashboard-data-result"
        }
      ]
    }
  }
}
