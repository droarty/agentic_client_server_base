{
  "name": "log-review",
  "version": "1.0.0",
  "initialState": {
    "config": {
      "idField": "_id",
      "triggerFields": ["name", "type", "createdAt"],
      "contentIdField": "_id",
      "contentTriggerFields": ["handlerName", "createdAt", "executionId"]
    }
  },
  "handlers": {
    "initialize": {
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-reviewable-documents", "responseType": "initialize-document" }
        }
      ]
    },
    "initialize-document": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-client",
            "initialState": {
              "config": {
                "idField": "_id",
                "triggerFields": ["name", "type", "createdAt"],
                "contentIdField": "_id",
                "contentTriggerFields": ["handlerName", "createdAt", "executionId"]
              }
            },
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "smartAccordion",
                    "props": {
                      "items": "temp.documentList",
                      "idField": "state.config.idField",
                      "triggerFields": "state.config.triggerFields",
                      "selectedId": "state.selectedDocumentId"
                    },
                    "emits": { "select": "select-log-document" },
                    "children": [
                      {
                        "componentType": "smartAccordion",
                        "props": {
                          "items": "state.selectedDocumentLogs",
                          "idField": "state.config.contentIdField",
                          "triggerFields": "state.config.contentTriggerFields",
                          "selectedId": "state.selectedLogId"
                        },
                        "emits": { "select": "select-log-entry" },
                        "children": [
                          {
                            "componentType": "logTreePanel",
                            "props": { "treeData": "state.selectedLogTree" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "temp.documentList", "value": "$message.documents" }
            ]
          }
        }
      ]
    },
    "select-log-document": {
      "condition": "$message.id",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-workflow-logs", "responseType": "workflow-logs-result" }
        }
      ]
    },
    "workflow-logs-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "state.selectedDocumentId", "value": "$message.id" },
              { "actionType": "update", "path": "state.selectedDocumentLogs", "value": "$message.workflowLogs" }
            ]
          }
        }
      ]
    },
    "select-log-entry": {
      "condition": "$message.id",
      "steps": [
        {
          "route": "database-query",
          "query": { "name": "get-log-tree", "responseType": "log-tree-result" }
        }
      ]
    },
    "log-tree-result": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "state.selectedLogId", "value": "$message.id" },
              { "actionType": "update", "path": "state.selectedLogTree", "value": "$message.treeData" }
            ]
          }
        }
      ]
    }
  }
}
