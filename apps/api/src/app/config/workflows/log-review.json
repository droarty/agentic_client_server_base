{
  "name": "log-review",
  "version": "1.0.0",
  "initialState": {},
  "handlers": {
    "initializeState": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-state",
            "initialState": {}
          }
        }
      ]
    },
    "defaultView": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "initialize-view",
            "viewHandler": "defaultView",
            "layoutConfig": [
              {
                "componentType": "fullPanel",
                "children": [
                  {
                    "componentType": "logTreePanel",
                    "props": {
                      "treeData": "@temp.logTree",
                      "selectedLog": "@temp.selectedLog",
                      "artifactState": "@temp.artifactState"
                    },
                    "emits": { "select": "select-log" }
                  }
                ]
              }
            ]
          }
        },
        {
          "route": "database-query",
          "query": { "name": "get-artifact-log-tree", "responseType": "log-tree-loaded" }
        }
      ]
    },
    "log-tree-loaded": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.logTree", "value": "$message.treeData" },
              { "actionType": "update", "path": "$temp.artifactState", "value": "$message.artifactState" }
            ]
          }
        }
      ]
    },
    "select-log": {
      "steps": [
        {
          "route": "client",
          "transform": {
            "clientMessageType": "update-state",
            "actions": [
              { "actionType": "update", "path": "$temp.selectedLog", "value": "$message.selectedLog" }
            ]
          }
        }
      ]
    }
  }
}
