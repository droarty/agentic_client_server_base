NODE_ENV=development
REDIS_URL=redis://localhost:6379
PORT=3000
MONGODB_URI=mongodb://localhost:27017/agentic_client_server_base
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4200
CLIENT_URL=http://localhost:4200

# Google OAuth 2.0
# Create credentials at https://console.developers.google.com
# Under APIs & Services > Credentials > Create OAuth 2.0 Client ID
# Set Authorised redirect URI to: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
